<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF1D1"
    tools:context=".UI.Inicio">

    <Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#A30000">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="FOLIADEIR@S"
        android:textColor="@color/white"
        android:fontFamily="@font/jeju_hallasan"
        android:textSize="40dp"
        android:gravity="center" />
    </Toolbar>

    <ImageView
        android:id="@+id/logo"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:src="@drawable/logo"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/toolbar"/>

    <Button
        android:id="@+id/bt_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#A30000"
        android:layout_below="@+id/logo"
        android:layout_centerHorizontal="true"
        android:text="Iniciar Sesión" />

    <Button
        android:id="@+id/bt_rexistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#A30000"
        android:layout_below="@+id/bt_login"
        android:layout_marginTop="25dp"
        android:layout_centerHorizontal="true"
        android:text="Rexistrarse"/>

</RelativeLayout>